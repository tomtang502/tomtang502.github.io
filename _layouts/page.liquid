---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<!-- Gate ward: the page title carries the map's one green rule -->
<div class="ward s6 gate post">
  <header class="post-header">
    <h1 class="post-title display-name">{{ page.title }}</h1>
    {% if page.description and page.description != '' %}
      <p class="desc">
        {{ page.description -}}
        <span class="cursor"></span>
      </p>
    {% endif %}
  </header>
</div>

{% if page.ward_self %}
  <!-- The page supplies its own wards -->
  {{ content }}
{% else %}
  <div class="ward s6 content-ward post">
    <span class="fang">{{ page.title | slugify }}</span>
    <article>
      {{ content }}
    </article>

    {% if page.related_publications %}
      <h2>References</h2>
      <div class="publications">
        {% bibliography --cited_in_order %}
      </div>
    {% endif %}

    {% if site.giscus and page.giscus_comments %}
      {% include giscus.liquid %}
    {% endif %}
  </div>
{% endif %}
