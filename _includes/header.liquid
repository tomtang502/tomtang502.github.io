<!-- Nav wards (style-guide-03 §5.1) — direct children of .ward-map -->
<div class="ward s2 nav-cell">
  <a class="logo" href="{{ site.baseurl }}/">
    <span class="seal" aria-hidden="true">T</span>
    {%- if site.title == 'blank' -%}
      {{- site.first_name }}
      {{ site.middle_name }}
      {{ site.last_name -}}
    {%- else -%}
      {{- site.title -}}
    {%- endif -%}
  </a>
  <nav class="nav-links logo-links">
    {% for p in site.pages %}
      {% if p.permalink == '/' %}{% assign about_title = p.title %}{% endif %}
    {% endfor %}
    <a href="{{ '/' | relative_url }}">
      {{- about_title -}}
      {%- if page.permalink == '/' -%}
        <span class="sr-only">(current)</span>
      {%- endif -%}
    </a>
  </nav>
</div>
<div class="ward s3 nav-cell">
  <nav class="nav-links">
    {% assign sorted_pages = site.pages | sort: 'nav_order' %}
    {% for p in sorted_pages %}
      {% if p.nav and p.autogen == null and p.dropdown == null %}
        {% if p.permalink contains '/blog/' %}{% assign url = '/blog/' %}{% else %}{% assign url = p.url %}{% endif %}
        <a class="{% if page.url contains p.url %}on{% endif %}" href="{{ url | relative_url }}">
          {{- p.title -}}
          {%- if page.url contains p.url -%}
            <span class="sr-only">(current)</span>
          {%- endif -%}
        </a>
      {% endif %}
    {% endfor %}
  </nav>
</div>
<div class="ward s1 nav-cell chip-cell">
  <div class="status-chip"><i></i>MFU 49%</div>
</div>
